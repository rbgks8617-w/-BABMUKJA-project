generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Restaurant {
  id          String         @id
  name        String
  building    String
  category    String
  location    String
  description String
  imageUrl    String        @map("image_url")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  menus       Menu[]
  mealMates   MealMateRoom[]

  @@index([building])
  @@index([category])
  @@map("restaurants")
}

model Menu {
  id           String      @id
  restaurantId String      @map("restaurant_id")
  name         String
  category     String
  price        Int
  description  String
  imageUrl     String      @map("image_url")
  tags         String[]    @default([])
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orderItems   OrderItem[]

  @@index([restaurantId])
  @@index([category])
  @@map("menus")
}

model Review {
  id         String          @id
  title      String
  body       String
  tasteScore Decimal         @map("taste_score") @db.Decimal(2, 1)
  valueScore Decimal         @map("value_score") @db.Decimal(2, 1)
  imageUrl   String?         @map("image_url")
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")
  comments   ReviewComment[]

  @@index([createdAt])
  @@map("reviews")
}

model ReviewComment {
  id           String   @id
  reviewId     String   @map("review_id")
  body         String
  anonymousKey String   @map("anonymous_key")
  createdAt    DateTime @default(now()) @map("created_at")
  review       Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@index([createdAt])
  @@map("review_comments")
}

model MealMateRoom {
  id           String     @id
  restaurantId String     @map("restaurant_id")
  time         String
  topic        String
  note         String     @default("")
  currentCount Int        @default(1) @map("current_count")
  maxCount     Int        @map("max_count")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Restrict)

  @@index([restaurantId])
  @@index([createdAt])
  @@map("meal_mate_rooms")
}

model Order {
  id         String      @id
  status     OrderStatus @default(CREATED)
  totalPrice Int         @map("total_price")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  items      OrderItem[]

  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id                String   @id @default(cuid())
  orderId           String   @map("order_id")
  menuId            String   @map("menu_id")
  quantity          Int
  selectedOptionIds String[] @default([]) @map("selected_option_ids")
  order             Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menu              Menu     @relation(fields: [menuId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([menuId])
  @@map("order_items")
}

enum OrderStatus {
  CREATED
  PAID
  READY
  COMPLETED
}
